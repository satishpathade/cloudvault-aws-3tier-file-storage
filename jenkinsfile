pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'satishpathade/cloudvaultapp'
        IMAGE_TAG = "${BUILD_NUMBER}"

        DB_HOST     = credentials('db-host')
        DB_NAME     = credentials('db-name')
        DB_USERNAME = credentials('db-username')
        DB_PASSWORD = credentials('db-password')
        SECRET_KEY  = credentials('secret-key')
        AWS_REGION  = credentials('aws-region')
        S3_BUCKET   = credentials('s3-bucket')
        AWS_ACCESS_KEY_ID     = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/satishpathade/cloudvault-aws-3tier-devsecops.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                        sonar-scanner \
                        -Dsonar.projectKey=cloudvault-app \
                        -Dsonar.projectName=cloudvault-app \
                        -Dsonar.sources=app
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build -t $DOCKER_IMAGE:$IMAGE_TAG -f docker/Dockerfile .
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                    trivy image --severity HIGH,CRITICAL --exit-code 0 $DOCKER_IMAGE:$IMAGE_TAG
                '''
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-credentials',
                        usernameVariable: 'DOCKERHUB_USERNAME',
                        passwordVariable: 'DOCKERHUB_PASSWORD'
                    )
                ]) {
                    sh '''
                        echo $DOCKERHUB_PASSWORD | docker login -u $DOCKERHUB_USERNAME --password-stdin
                        docker push $DOCKER_IMAGE:$IMAGE_TAG
                        docker logout
                    '''
                }
            }
        }

        // stage ('Ansible playbook run'){
        //     steps {
        //         dir('ansible') {
        //             sh '''
        //                 ansible-playbook playbooks/site.yml
        //             '''
        //         }
        //     }
        // } 

        stage('Create ConfigMap') {
            steps {
                sh '''
                    kubectl create configmap cloudvault-config \
                        --from-literal=DB_HOST="$DB_HOST" \
                        --from-literal=DB_NAME="$DB_NAME" \
                        --from-literal=AWS_REGION="$AWS_REGION" \
                        --from-literal=S3_BUCKET="$S3_BUCKET" \
                        -n cloudvault \
                        --dry-run=client -o yaml | kubectl apply -f -
                '''
            }
        }

        stage('Create Secret') {
            steps {
                sh '''
                    kubectl create secret generic cloudvault-secret \
                        --from-literal=DB_USERNAME="$DB_USERNAME" \
                        --from-literal=DB_PASSWORD="$DB_PASSWORD" \
                        --from-literal=SECRET_KEY="$SECRET_KEY" \
                        --from-literal=AWS_ACCESS_KEY_ID="$AWS_ACCESS_KEY_ID" \
                        --from-literal=AWS_SECRET_ACCESS_KEY="$AWS_SECRET_ACCESS_KEY" \
                        -n cloudvault \
                        --dry-run=client -o yaml | kubectl apply -f -
                '''
            }
        }

        stage('Deploy to kubernetes') {
            steps {
                sh '''
                    kubectl apply -f kubernetes/namespace.yml
                    kubectl apply -f kubernetes/deployment.yml
                    kubectl set image deployment/cloudvault-app cloudvault-app=$DOCKER_IMAGE:$IMAGE_TAG -n cloudvault
                '''
            }
        }

    }

    post {
        success {
            echo 'CloudVault deployed successfully.'
        }

        failure {
            echo 'Pipeline Failed'
        }
    }

}