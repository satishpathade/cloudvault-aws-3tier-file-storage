pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'satishpathade/cloudvaultapp'
        IMAGE_TAG = "${BUILD_NUMBER}"
        SECRET_NAME = 'cloudvault-secret'

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/satishpathade/cloudvault-aws-3tier-file-storage.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                        sonar-scanner \
                        -Dsonar.projectKey=cloudvault-app \
                        -Dsonar.projectName=cloudvault-app \
                        -Dsonar.sources=app
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build -t $DOCKER_IMAGE:$IMAGE_TAG -f docker/Dockerfile .
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                    trivy image --severity HIGH,CRITICAL --exit-code 0 $DOCKER_IMAGE:$IMAGE_TAG
                '''
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-credentials',
                        usernameVariable: 'DOCKERHUB_USERNAME',
                        passwordVariable: 'DOCKERHUB_PASSWORD'
                    )
                ]) {
                    sh '''
                        echo $DOCKERHUB_PASSWORD | docker login -u $DOCKERHUB_USERNAME --password-stdin
                        docker push $DOCKER_IMAGE:$IMAGE_TAG
                        docker logout
                    '''
                }
            }
        }

        // stage ('Ansible playbook run'){
        //     steps {
        //         dir('ansible') {
        //             sh '''
        //                 ansible-playbook playbooks/site.yml
        //             '''
        //         }
        //     }
        // } 

        stage('create k8s namespace') {
            steps {
                sh '''
                    kubectl apply -f kubernetes/namespace.yml
                '''
            }
        }

        stage('Create ConfigMap') {
            steps {
                sh '''
                    SECRET_JSON=$(aws secretsmanager get-secret-value \
                        --secret-id "$SECRET_NAME" \
                        --query SecretString \
                        --output text)

                    DB_HOST=$(echo "$SECRET_JSON" | jq -r '.DB_HOST')
                    DB_NAME=$(echo "$SECRET_JSON" | jq -r '.DB_NAME')
                    AWS_REGION=$(echo "$SECRET_JSON" | jq -r '.AWS_REGION')
                    S3_BUCKET=$(echo "$SECRET_JSON" | jq -r '.S3_BUCKET')

                    kubectl create configmap cloudvault-config \
                        --from-literal=DB_HOST="$DB_HOST" \
                        --from-literal=DB_NAME="$DB_NAME" \
                        --from-literal=AWS_REGION="$AWS_REGION" \
                        --from-literal=S3_BUCKET="$S3_BUCKET" \
                        -n cloudvault \
                        --dry-run=client -o yaml | kubectl apply -f -
                '''
            }
        }

        stage('Create Secret') {
            steps {
                sh '''
                    SECRET_JSON=$(aws secretsmanager get-secret-value \
                        --secret-id "$SECRET_NAME" \
                        --query SecretString \
                        --output text)

                    DB_USERNAME=$(echo "$SECRET_JSON" | jq -r '.DB_USERNAME')
                    DB_PASSWORD=$(echo "$SECRET_JSON" | jq -r '.DB_PASSWORD')
                    SECRET_KEY=$(echo "$SECRET_JSON" | jq -r '.SECRET_KEY')

                    kubectl create secret generic cloudvault-secret \
                        --from-literal=DB_USERNAME="$DB_USERNAME" \
                        --from-literal=DB_PASSWORD="$DB_PASSWORD" \
                        --from-literal=SECRET_KEY="$SECRET_KEY" \
                        -n cloudvault \
                        --dry-run=client -o yaml | kubectl apply -f -
                '''
            }
        }

        stage('Deploy to kubernetes') {
            steps {
                sh '''
                    kubectl apply -f kubernetes/service.yml
                    kubectl apply -f kubernetes/deployment.yml

                    kubectl set image deployment/cloudvault-app \
                    cloudvault-app=$DOCKER_IMAGE:$IMAGE_TAG \
                    -n cloudvault

                    kubectl rollout status deployment/cloudvault-app \
                    -n cloudvault
                '''
            }
        }

    }

    post {
        success {
            echo 'CloudVault deployed successfully.'
        }

        failure {
            echo 'Pipeline Failed'
        }
    }

}